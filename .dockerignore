.env
*.pyc
__pycache__
redis-data

# Dev-only — never needed in the image, and .venv/.git alone are ~1GB of
# pure waste in every build (COPY . . was copying them wholesale before
# this was added).
.venv/
.git/
.pytest_cache/
.ruff_cache/

# Local pipeline/ML artifacts — regenerated by make train/export/warehouse,
# not needed at runtime. Left out of the build context before, they'd get
# baked into the image by COPY . . (bloat, and risk of shipping trained
# models / business data into a registry unintentionally).
mlflow.db
mlflow.db-*
mlruns/
models/*.pkl
data_lake/
feature_store/
warehouse/*.duckdb
