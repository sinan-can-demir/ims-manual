# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------
# Local dev default — change for staging/prod
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ims

# Postgres URL for integration tests. When set, tests run against real Postgres.
# When unset, tests use SQLite in-memory (postgres-marked tests are skipped).
TEST_DATABASE_URL=

# -------------------------------------------------------------------
# SQLAlchemy connection pool
# Pool size: number of persistent connections kept open
# Max overflow: extra connections allowed above pool_size under load
# -------------------------------------------------------------------
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# -------------------------------------------------------------------
# API
# -------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS.
# In production set this to your frontend domain, e.g.:
#   CORS_ORIGINS=https://dashboard.yourdomain.com
CORS_ORIGINS=http://localhost:8501

# API key for all /api endpoints.
# Leave unset to disable auth (local dev only).
# In production, set this to a long random string, e.g.:
#   openssl rand -hex 32
API_KEY=

# Shared secret for verifying POST /api/webhooks/ingest requests
# (X-Webhook-Signature header, HMAC-SHA256 over the raw request body).
# Leave unset to disable signature verification (local dev only).
# In production, set this to a long random string, e.g.:
#   openssl rand -hex 32
WEBHOOK_SECRET=

# Default rate limit applied to /api routes (slowapi syntax, e.g. "100/minute").
# Keyed by client IP. /health, /metrics, and the signature-verified webhook
# endpoint are exempt. NOTE: storage is per-worker-process, not shared across
# Gunicorn workers in prod — effective limit there is ~WEB_CONCURRENCY x this
# value. See SECURITY.md.
RATE_LIMIT=100/minute

# -------------------------------------------------------------------
# Data pipeline paths (override if running outside the project root)
# -------------------------------------------------------------------
DATA_LAKE_ROOT=./data_lake
WAREHOUSE_ROOT=./warehouse
FEATURE_STORE_PATH=./feature_store
MODELS_DIR=./models

# -------------------------------------------------------------------
# Warehouse date range
# -------------------------------------------------------------------
WAREHOUSE_START_DATE=2020-01-01
WAREHOUSE_END_DATE=2030-12-31

# -------------------------------------------------------------------
# docker-compose.prod.yml / docker-compose.caddy.yml only
# (self-hosted deployment — see docs/deployment/self-hosted.md).
# Not read directly by the app; used for compose-level variable
# substitution to build DATABASE_URL and avoid the dev default password.
# -------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=ims

# Domain pointed at your server, for automatic HTTPS via Caddy.
# Leave unset if you're not using docker-compose.caddy.yml.
DOMAIN=

# Basic-auth credentials protecting the Streamlit dashboard at
# https://<DOMAIN>:8501 (docker-compose.caddy.yml only — the dashboard has
# no auth of its own; without this overlay it isn't reachable at all).
# Generate the hash with the command below — note the `sed` at the end:
# bcrypt hashes contain literal `$` characters, and Compose's .env-file
# interpolation treats unescaped `$word` as a variable reference, silently
# truncating the hash. The `sed` doubles each `$` (`$$`) so Compose passes
# the hash through unmangled.
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext '<password>' | sed 's/\$/$$/g'
DASHBOARD_AUTH_USER=
DASHBOARD_AUTH_HASH=

# Number of Gunicorn worker processes serving the API (production only —
# the base docker-compose.yml dev command ignores this and always runs a
# single Uvicorn process). Rule of thumb: 2x vCPU cores + 1.
WEB_CONCURRENCY=4

# -------------------------------------------------------------------
# Observability
# -------------------------------------------------------------------
# Directory prometheus_client uses to merge /metrics data across Gunicorn's
# worker processes. Already set in docker-compose.prod.yml — only needed
# here if running Gunicorn with WEB_CONCURRENCY > 1 outside Compose.
# See docs/observability.md.
PROMETHEUS_MULTIPROC_DIR=
